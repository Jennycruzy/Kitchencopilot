# =============================================================
# KitchenCopilot — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values

# ── Model Provider (choose ONE) ──────────────────────────────
# Option 1: OpenAI (cloud, vision-capable)
# OPENAI_API_KEY=sk-...

# Option 2: Anthropic
# ANTHROPIC_API_KEY=

# Option 3: Ollama (local — free, GPU-accelerated)
# OLLAMA_SERVER_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2-vision:latest

# Option 4: Nosana GPU (set OLLAMA_SERVER_URL to your Nosana endpoint)
# OLLAMA_SERVER_URL=https://your-nosana-endpoint.nosana.io

# ── ElizaOS Agent ────────────────────────────────────────────
ELIZAOS_PORT=3000
LOG_LEVEL=info

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string

# ── Database ─────────────────────────────────────────────────
DATABASE_PATH=./data/kitchensync.db

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Nosana Deployment (fill in when deploying to Nosana GPU) ──
# NOSANA_API_KEY=
# NOSANA_ENDPOINT=
