{
    "name": "kitchen-copilot",
    "version": "1.0.0",
    "type": "module",
    "private": true,
    "engines": {
        "node": ">=22.0.0"
    },
    "scripts": {
        "start": "node --experimental-specifier-resolution=node dist/index.js",
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "install:all": "npm install && cd packages/plugin-kitchen && npm install && cd ../../frontend && npm install",
        "dev:all": "concurrently \"npm run dev\" \"cd frontend && npm run dev\""
    },
    "dependencies": {
        "@elizaos/core": "^1.0.0",
        "@elizaos/plugin-sql": "^1.0.0",
        "@elizaos/server": "^1.0.0",
        "bcryptjs": "^2.4.3",
        "better-sqlite3": "^9.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "uuid": "^9.0.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/better-sqlite3": "^7.6.13",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.25",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^1.4.13",
        "@types/node": "^20.12.12",
        "@types/uuid": "^9.0.8",
        "concurrently": "^8.2.2",
        "drizzle-kit": "^0.31.10",
        "tsx": "^4.7.1",
        "typescript": "^5.4.5"
    },
    "resolutions": {
        "@types/express-serve-static-core": "4.19.8",
        "@elizaos/core": "1.7.2",
        "@elizaos/plugin-sql": "1.7.2"
    },
    "workspaces": [
        "packages/*"
    ]
}